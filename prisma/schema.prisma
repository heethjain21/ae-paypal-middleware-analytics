// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator kysely {
  provider     = "prisma-kysely"
  output       = "./generated/types"
  fileName     = "database.types.ts"
  enumFileName = "database.enums.ts"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PPCP_Request {
  debug_id String @id

  site_url String?
  status   String

  path        String
  method      String
  status_code Int    @db.SmallInt
  duration    Int

  paypal_request_id String?

  raw_request  Json?
  raw_response Json?

  error_code    String?
  error_message String?
  error_stack   Json?

  is_sandbox          Boolean @default(false)
  plugin_version      String?
  internal_request_id String?

  action_name String?

  created_at DateTime @default(now()) @db.Timestamptz(3)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(3)

  @@index([site_url, status, created_at])
  @@index([path, status, created_at])
  @@index([created_at])
  @@index([is_sandbox])
  @@map("ppcp_requests")
}

model PPCP_Payment {
  capture_id String @id

  site_url String?
  path     String
  duration Int

  net_amount   Decimal? @db.Decimal(19, 4)
  paypal_fee   Decimal? @db.Decimal(19, 4)
  gross_amount Decimal? @db.Decimal(19, 4)
  platform_fee Decimal? @db.Decimal(19, 4)
  currency     String?  @db.VarChar(3)

  status             String?
  merchant_id        String?
  custom_id          String?
  invoice_id         String?
  paypal_create_time DateTime? @db.Timestamptz(3)
  paypal_update_time DateTime? @db.Timestamptz(3)

  debug_id       String
  is_sandbox     Boolean @default(false)
  plugin_version String?

  created_at DateTime @default(now()) @db.Timestamptz(3)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(3)

  @@index([site_url, status, created_at])
  @@index([path, status, created_at])
  @@index([debug_id])
  @@index([is_sandbox])
  @@map("ppcp_payments")
}

model All_Payment {
  trxn_id String @id @default(uuid())

  site_url    String?
  merchant_id String?
  req_status  String?

  gross_amount Decimal? @db.Decimal(19, 4)
  currency     String?  @db.VarChar(3)

  correlation_id String?
  trxn_type      String?

  product_id Int?    @db.SmallInt
  is_sandbox Boolean @default(false)

  created_at DateTime @default(now()) @db.Timestamptz(3)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(3)

  @@index([merchant_id, req_status, created_at])
  @@index([product_id, req_status, created_at])
  @@index([correlation_id])
  @@index([is_sandbox])
  @@map("all_payments")
}

model Payment {
  trxn_id    String @default(uuid())
  req_status String

  site_url    String?
  merchant_id String?

  net_amount   Decimal? @db.Decimal(19, 4)
  paypal_fee   Decimal? @db.Decimal(19, 4)
  gross_amount Decimal? @db.Decimal(19, 4)
  platform_fee Decimal? @db.Decimal(19, 4)
  currency     String?  @db.VarChar(3)

  correlation_id String?
  trxn_type      String?

  custom_id  String?
  invoice_id String?
  debug_id   String?
  meta_data  Json?

  product_id Int?    @db.SmallInt
  is_sandbox Boolean @default(false)

  created_at DateTime @default(now()) @db.Timestamptz(3)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(3)

  @@id([trxn_id, req_status])
  @@index([merchant_id, req_status, created_at])
  @@index([product_id, req_status, created_at])
  @@index([correlation_id])
  @@index([debug_id])
  @@index([is_sandbox])
  @@map("payments")
}

model Payment_Sandbox {
  trxn_id    String @default(uuid())
  req_status String

  site_url    String?
  merchant_id String?

  net_amount   Decimal? @db.Decimal(19, 4)
  paypal_fee   Decimal? @db.Decimal(19, 4)
  gross_amount Decimal? @db.Decimal(19, 4)
  platform_fee Decimal? @db.Decimal(19, 4)
  currency     String?  @db.VarChar(3)

  correlation_id String?
  trxn_type      String?

  custom_id  String?
  invoice_id String?
  debug_id   String?
  meta_data  Json?

  product_id Int?    @db.SmallInt
  is_sandbox Boolean @default(false)

  created_at DateTime @default(now()) @db.Timestamptz(3)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(3)

  @@id([trxn_id, req_status])
  @@index([merchant_id, created_at])
  @@index([product_id, created_at])
  @@index([trxn_type, created_at])
  @@map("payments_sandbox")
}
